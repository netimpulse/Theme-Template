# Beispiel-Konfiguration. KEINE echten Secrets in diese Datei eintragen.
# Die echte .env wird per .gitignore ignoriert und nur lokal/in der Session gefuellt.

# Shopify Theme Access Token (Theme Access App im Dev-Store erzeugt)
SHOPIFY_CLI_THEME_TOKEN=shptka_HIER_TOKEN_EINSETZEN

# Optional: Shop ueberschreiben (sonst aus shopify.theme.toml)
# SHOPIFY_FLAG_STORE=dev-store-4ogqgshg.myshopify.com
